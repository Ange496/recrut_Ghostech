{
  "version": 2,
  "buildCommand": "cd backend && npm install",
  "installCommand": "npm install",
  "env": {
    "EMAIL_USER": "@ghostech-email-user",
    "EMAIL_PASS": "@ghostech-email-pass",
    "RECIPIENT_EMAIL": "@ghostech-recipient-email",
    "PORT": "3000"
  },
  "functions": {
    "backend/server.js": {
      "memory": 128,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/ghostech-recrutement.html"
    }
  ]
}
